# InsForge API
INSFORGE_BASE=https://rme548ii.ap-southeast.insforge.app
INSFORGE_API_KEY=your-insforge-api-key

# Google OAuth (for login + Google Workspace)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (for Canvas deployment)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Gmail SMTP (for OTP verification emails — requires 2FA + App Password)
SMTP_EMAIL=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password

# Server port (default: 3000)
PORT=3000
